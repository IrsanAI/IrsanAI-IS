# IrsanAI IS -- Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.

# Anthropic (Primary Weapon slot)
ANTHROPIC_API_KEY=

# OpenAI (Off-hand slot -- optional)
OPENAI_API_KEY=

# Google (Off-hand slot -- optional)
GOOGLE_GENERATIVE_AI_API_KEY=

# Supabase (Helmet slot -- memory system)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# IS Config
IS_DEFAULT_LOADOUT=software-engineering
IS_META_ROUTER_MODEL=claude-sonnet-4-6
IS_LOG_LEVEL=info
